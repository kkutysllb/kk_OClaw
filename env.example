# ============================================================================
# LLM 配置
# ============================================================================
DeepSeek_API_KEY=
DeepSeek_BASE_URL=
DeepSeek_MODEL1=
DeepSeek_MODEL2=

# MiniMax 配置（可选）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Qwen 配置（可选，本地部署）
QWEN_API_KEY=
QWEN_BASE_URL=http://127.0.0.1:8792/v1
QWEN_MODEL=Qwen3-32B-AWQ

# ============================================================================
# 端口配置
# ============================================================================
# LangGraph API 端口
LANGGRAPH_PORT=2166
# Gateway API 端口
GATEWAY_PORT=8874
# Frontend 端口
FRONTEND_PORT=7677

# ============================================================================
# 渠道配置（IM 集成）
# ============================================================================
# 渠道系统使用的 Gateway API 地址，默认根据 GATEWAY_PORT 自动构建
# KKOCLAW_CHANNELS_LANGGRAPH_URL=http://localhost:{GATEWAY_PORT}/api
# KKOCLAW_CHANNELS_GATEWAY_URL=http://localhost:{GATEWAY_PORT}

# ============================================================================
# CORS 配置
# ============================================================================
# Gateway CORS 允许的来源，默认匹配 FRONTEND_PORT
# CORS_ORIGINS=http://localhost:{FRONTEND_PORT}