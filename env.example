# ============================================================================
# LLM 配置
# ============================================================================
DeepSeek_API_KEY=
DeepSeek_BASE_URL=
DeepSeek_MODEL1=
DeepSeek_MODEL2=

# MiniMax 配置（可选）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Qwen 配置（可选，本地部署）
QWEN_API_KEY=
QWEN_BASE_URL=http://127.0.0.1:8792/v1
QWEN_MODEL=Qwen3-32B-AWQ

# ============================================================================
# 端口配置
# ============================================================================
# Nginx 公共端口（反向代理入口）
NGINX_PORT=2166
# Gateway API 端口（合并了 LangGraph Agent Runtime）
GATEWAY_PORT=8874
# Frontend 端口
FRONTEND_PORT=7677

# ============================================================================
# 安全配置
# ============================================================================
# Auth 代理信任：允许 Gateway 读取 nginx 设置的 X-Real-IP，
# 否则所有请求都显示 nginx 的 IP (::1)，触发共享速率限制导致 429
AUTH_TRUSTED_PROXIES=127.0.0.1,::1

# JWT 密钥：若不设置则每次重启生成临时密钥，已登录会话全部失效
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_JWT_SECRET=

# ============================================================================
# 渠道配置（IM 集成）
# ============================================================================
# 渠道系统使用的 Gateway API 地址，默认根据 GATEWAY_PORT 自动构建
# KKOCLAW_CHANNELS_LANGGRAPH_URL=http://localhost:{GATEWAY_PORT}/api
# KKOCLAW_CHANNELS_GATEWAY_URL=http://localhost:{GATEWAY_PORT}

# ============================================================================
# CORS 配置
# ============================================================================
# Gateway CORS 允许的来源（Nginx 代理入口 + 前端直连）
# CORS_ORIGINS=http://localhost:{FRONTEND_PORT}
# GATEWAY_CORS_ORIGINS=http://localhost:{NGINX_PORT},http://localhost:{FRONTEND_PORT}