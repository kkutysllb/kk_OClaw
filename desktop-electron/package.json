{
  "name": "kkoclaw-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "OClaw desktop — fully self-contained Electron shell wrapping the OClaw frontend and Python gateway.",
  "homepage": "https://github.com/kkutysllb/kk_OClaw",
  "author": "OClaw Team <13609247807@139.com>",
  "maintainer": "OClaw Team <13609247807@139.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && mv -f dist/preload.js dist/preload.cjs",
    "dev": "node scripts/dev.mjs",
    "start": "electron .",
    "build:icons": "bash scripts/generate-icons.sh",
    "build:gateway": "bash scripts/build-gateway.sh",
    "build:frontend": "pnpm --dir ../frontend run build:desktop",
    "verify:package-resources": "node scripts/verify-package-resources.mjs",
    "fix:node-pty-permissions": "node scripts/fix-node-pty-permissions.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs",
    "build:app": "pnpm run build && pnpm run build:gateway && pnpm run build:frontend && pnpm run verify:package-resources && electron-builder",
    "build:app:full": "pnpm run build:app",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.preload.json --noEmit"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
