# ============================================================================
# KKOCLAW Desktop Client Environment Variables
# ============================================================================
# This file is used when running KKOCLAW as a desktop application via Electron.
# It overrides the default web configuration to connect to the embedded gateway.
#
# NOTE: ports here MUST NOT collide with the local web deployment (9987/8659).
# Desktop uses 19987 to stay fully isolated.

# Direct connection to the embedded gateway (no Nginx proxy needed)
NEXT_PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:19987
NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://127.0.0.1:19987/api

# Gateway port (desktop-only; the web deployment uses a different port)
GATEWAY_PORT=19987
