# ============================================================================
# KKOCLAW Desktop Client Environment Variables
# ============================================================================
# This file is used when running KKOCLAW as a desktop application via Tauri.
# It overrides the default web configuration to connect to the embedded gateway.

# Direct connection to the embedded gateway (no Nginx proxy needed)
NEXT_PUBLIC_BACKEND_BASE_URL=http://127.0.0.1:9987
NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://127.0.0.1:9987/api

# Gateway port (must match GATEWAY_PORT in root .env)
GATEWAY_PORT=9987
